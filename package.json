  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' react-router dev",
    "dev:serve": "NODE_OPTIONS=\"--import tsx/esm --import ./mocks/index.ts\" react-router-serve ./build/server/index.js",
    "format": "prettier --write .",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint --max-warnings=0 .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix --max-warnings=0 .",
    "setup": "prisma generate && prisma migrate deploy && prisma db seed",
    "start": "NODE_ENV=production NODE_OPTIONS='--import ./instrument.server.mjs' react-router-serve ./build/server/index.js",
    "start:mocks": "NODE_OPTIONS=\"--import tsx/esm --import ./mocks/index.ts\" react-router-serve ./build/server/index.js",
    "test": "vitest",
    "pretest:e2e:run": "npm run build",
    "test:e2e:run": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:db:migrate": "node --env-file=.env.test ./node_modules/.bin/prisma migrate deploy",
    "dev:db:reset": "node --env-file=.env ./node_modules/.bin/prisma migrate reset --force --skip-seed",
    "test:db:reset": "node --env-file=.env.test ./node_modules/.bin/prisma migrate reset --force --skip-seed",
    "typecheck": "react-router typegen && tsc",
    "storybook": "BROWSER=firefox storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
